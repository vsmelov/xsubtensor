# Скопируйте в .env.subnet-slam и подставьте NETUID после создания semantic-slam сабнета.
#   cp .env.subnet-slam.example .env.subnet-slam
#
# docker compose -f docker-compose.subnet-slam.yml --env-file .env.subnet-slam up -d --build

NETUID=5

SUBTENSOR_DOCKER_NETWORK=xsubtensor_default
SUBTENSOR_CHAIN_ENDPOINT=ws://subtensor-localnet:9944

MINER_WALLET=slam-miner
MINER_WALLET_B=slam-miner-b
VALIDATOR_WALLET=slam-val

KONNEX_SLAM_RUNTIME_BASE_URL=http://slam-runtime:8793
KONNEX_SLAM_RUNTIME_TIMEOUT=30

# SLAM_RUNTIME_HOST_PORT=8793
# WALLET_PATH=/home/ubuntu/knx-west/testnet-staging/.bittensor
