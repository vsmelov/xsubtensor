# Скопируйте в .env.subnet-math и подставьте NETUID после создания сабнета на цепи.
#   copy .env.subnet-math.example .env.subnet-math
#
# NETUID: возьмите из вывода `subnet create` (файл subnet-create.log) или `subnets list --json-out`.
# При пересоздании localnet с нуля или новом `subnet create` число меняется — обновите и этот файл.
#
# Неинтерактивное создание сабнета (все поля identity + фон): см. SUBNET_MATH_LOCALNET.md §4 и scripts/subnet-create-localnet.cmd
#
# Использование compose:
#   docker compose -f docker-compose.subnet-math.yml --env-file .env.subnet-math up -d --build

NETUID=1

# Сеть Docker, в которой висит localnet (docker network ls, имя проекта из каталога репо).
SUBTENSOR_DOCKER_NETWORK=xsubtensor_default

# Кошельки (coldkey name) — те же, что в btcli wallet / subnets register.
MINER_WALLET=math-miner
VALIDATOR_WALLET=math-val

# Вторая пара нод (docker-сервисы math-miner-b, math-validator-b; после создания кошельков и register+stake):
MINER_WALLET_B=math-miner-b
VALIDATOR_WALLET_B=math-val-b

# Необязательно: явный путь к ~/.bittensor на Windows.
# WALLET_PATH=C:/Users/you/.bittensor
