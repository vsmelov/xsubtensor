# Скопируйте в .env.subnet-vla и подставьте NETUID после создания сабнета VLA на цепи.
#   copy .env.subnet-vla.example .env.subnet-vla
#
# docker compose -f docker-compose.subnet-vla.yml --env-file .env.subnet-vla up -d --build

NETUID=3

SUBTENSOR_DOCKER_NETWORK=xsubtensor_default
SUBTENSOR_CHAIN_ENDPOINT=ws://subtensor-localnet:9944

MINER_WALLET=vla-miner
VALIDATOR_WALLET=vla-val

MINER_WALLET_B=vla-miner-b
VALIDATOR_WALLET_B=vla-val-b

MINER_WALLET_C=vla-miner-c

# WALLET_PATH=/home/ubuntu/knx-west/testnet-staging/.bittensor

# Optional: AI video verification — ключ подхватывается из subnet-vla/video-robot-eval/.env (см. docker-compose)
# или задайте здесь:
# OPENAI_API_KEY=<set locally>
# OPENAI_MODEL=gpt-4o-mini
# Kitchen runtime shim (по умолчанию поднимается тем же compose из ../kitchen-roboarm/services/task-api)
KONNEX_VLA_RUNTIME_BASE_URL=http://vla-kitchen-runtime:8080
KONNEX_VLA_RUNTIME_TIMEOUT=15
# KITCHEN_RUNTIME_HOST_PORT=8097
# From host calling probe with using_ai_verification: use http://127.0.0.1:8095
# From vla-probe container (default): http://vla-video-analyzer:8000
# VLA_VIDEO_ANALYZER_URL=http://vla-video-analyzer:8000
#
# Локальные MP4: subnet-vla/vla-video-static/<path> -> GET http://127.0.0.1:8094/videos/<path> (тот же vla-probe)
