# Скопируйте в .env.subnet-vla и подставьте NETUID после создания сабнета VLA на цепи.
#   copy .env.subnet-vla.example .env.subnet-vla
#
# docker compose -f docker-compose.subnet-vla.yml --env-file .env.subnet-vla up -d --build

NETUID=3

SUBTENSOR_DOCKER_NETWORK=xsubtensor_default

MINER_WALLET=vla-miner
VALIDATOR_WALLET=vla-val

MINER_WALLET_B=vla-miner-b
VALIDATOR_WALLET_B=vla-val-b

# WALLET_PATH=C:/Users/you/.bittensor
