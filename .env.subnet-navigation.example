# copy .env.subnet-navigation.example .env.subnet-navigation
# Подставьте NETUID после `subnet create` (лог subnet-create-navigation.log) или btcli subnets list.
#
# docker compose -f docker-compose.subnet-navigation.yml --env-file .env.subnet-navigation up -d --build

NETUID=4

SUBTENSOR_DOCKER_NETWORK=xsubtensor_default

MINER_WALLET=nav-miner
VALIDATOR_WALLET=nav-val
MINER_WALLET_B=nav-miner-b
VALIDATOR_WALLET_B=nav-val-b

# WALLET_PATH=C:/Users/you/.bittensor
